// app/Policies/ProjectPolicy.php

class ProjectPolicy
{
    public function view(User $user, Project $project)
    {
        return $user->company_id === $project->company_id;
    }

    public function update(User $user, Project $project)
    {
        return $user->id === $project->created_by
            || $project->members()->where('user_id', $user->id)
                                  ->where('role', 'manager')
                                  ->exists();
    }

    public function delete(User $user, Project $project)
    {
        return $user->id === $project->created_by;
    }
}

// AuthServiceProvider.php

protected $policies = [
    Project::class => ProjectPolicy::class,
];

$this->authorize('update', $project);


// app/Events/ModelChanged.php

class ModelChanged
{
    public function __construct(
        public $model,
        public $action,
        public $user
    ) {}
}

// app/Listeners/LogActivity.php

class LogActivity
{
    public function handle(ModelChanged $event)
    {
        ActivityLog::create([
            'user_id' => $event->user?->id,
            'company_id' => $event->model->company_id ?? null,
            'action' => $event->action,
            'module' => class_basename($event->model),
            'reference_id' => $event->model->id,
            'new_value' => $event->model->toArray(),
        ]);
    }
}

// EventServiceProvider.php

protected $listen = [
    ModelChanged::class => [
        LogActivity::class,
    ],
];


// app/Observers/ProjectObserver.php

class ProjectObserver
{
    public function created(Project $project)
    {
        event(new ModelChanged($project, 'created', auth()->user()));
    }

    public function updated(Project $project)
    {
        event(new ModelChanged($project, 'updated', auth()->user()));
    }

    public function deleted(Project $project)
    {
        event(new ModelChanged($project, 'deleted', auth()->user()));
    }
}


// AppServiceProvider.php

public function boot()
{
    Project::observe(ProjectObserver::class);
}

// app/DTOs/ProjectDTO.php

class ProjectDTO
{
    public function __construct(
        public string $title,
        public ?string $description,
        public string $company_id,
        public string $created_by
    ) {}

    public static function fromRequest($request): self
    {
        return new self(
            $request->title,
            $request->description,
            $request->company_id,
            auth()->id()
        );
    }
}


